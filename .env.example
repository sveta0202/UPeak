PORT=3000

# Apps Script деплой ПЛАНИРОВЩИКА (страница /planner.html, таблица PlannerEvents)
PLANNER_APPS_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_PLANNER_DEPLOYMENT/exec
PLANNER_APPS_SCRIPT_TOKEN=replace_with_long_random_secret

# Apps Script деплой РЕГИСТРАЦИИ (страница /participate.html, таблица Participants)
REGISTRATION_APPS_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_REGISTRATION_DEPLOYMENT/exec
REGISTRATION_APPS_SCRIPT_TOKEN=replace_with_long_random_secret

# Обратная совместимость: если PLANNER_APPS_SCRIPT_URL не задан, используется APPS_SCRIPT_URL.
# APPS_SCRIPT_URL=
# APPS_SCRIPT_SHARED_TOKEN=
